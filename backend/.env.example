# =====================================================
# N CARE HOSPITAL — Backend environment variables
# Copy this to `.env` and fill in real values.
# =====================================================

# ----- Server -----
PORT=4000
NODE_ENV=development
# Allow your frontend origin (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173,https://ncarehospital.com
# Public URL of the frontend (used in email templates).
PUBLIC_URL=https://ncarehospital.com

# ----- JWT -----
# Generate a strong random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace-me-with-a-strong-random-secret

# ----- Database (MongoDB) -----
# If unset, server runs in IN-MEMORY mode (data lost on restart) — fine for testing.
# For production, use MongoDB Atlas or self-hosted MongoDB.
# Example: MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/ncare?retryWrites=true&w=majority
MONGODB_URI=

# ----- Admin login -----
# Option A: ENV-defined admin (works without DB seeding, simplest for handover).
# Set both to enable. Anyone with these credentials can log in to /admin.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Option B: DB-seeded admin — run `npm run seed` once. These configure the seed.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme-now
SEED_ADMIN_NAME=Hospital Admin

# ----- SMS / OTP (Twilio) -----
# If unset, OTP is logged to the server console (dev mode).
# Get free credentials at https://www.twilio.com/try-twilio (or use MSG91 for India).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # e.g. +1xxxxxxxxxx

# ----- Email — recommended: RESEND (HTTP API, works on Render free tier) -----
# Sign up free at https://resend.com (3,000 emails/mo free).
# Render free tier BLOCKS outbound SMTP ports — Resend uses HTTPS (port 443).
RESEND_API_KEY=
RESEND_FROM="N Care Hospital <onboarding@resend.dev>"

# ----- OR: SMTP (Gmail App Password etc.) — works locally, blocked on Render free -----
# If RESEND_API_KEY is set, these are ignored.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="N Care Hospital <noreply@ncarehospital.com>"

HOSPITAL_NOTIFICATION_EMAIL=appointments@ncarehospital.com

# ----- Hospital details (used in email templates / SMS / chatbot) -----
HOSPITAL_NAME="N Care Hospital"
HOSPITAL_PHONE="+91 40 6162 6364"
HOSPITAL_ADDRESS="25-26, Mayuri Nagar, R.C. Puram, Beeramguda, Hyderabad — 502032"

# ----- Chatbot (Gemini) -----
# Get a free key at https://aistudio.google.com/apikey
# When unset, the chatbot scripted flows still work; only free-text Q&A is stubbed.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ----- Rate limiting -----
OTP_MAX_PER_HOUR=5
CHAT_MAX_PER_MINUTE=20
